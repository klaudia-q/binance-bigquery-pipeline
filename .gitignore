# ============================================
# .gitignore for Binance BigQuery Pipeline
# ============================================

# Credentials - NEVER commit these!
**/credentials.json
**/*-key.json
**/service-account*.json
nifi.properties
*.p12
*.jks
*.pem

# API Keys
.env
.env.local
config.json
secrets.yaml

# Logs
*.log
logs/
nifi-*.log

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Java
*.class
*.jar
*.war
*.ear
target/

# Temporary files
*.tmp
*.bak
*.swp
*~

# NiFi specific
flow.xml.gz
conf/flow.xml.gz
state/
work/
database_repository/
flowfile_repository/
content_repository/
provenance_repository/

# BigQuery
bq-export-*.json

# Archives
*.zip
*.tar.gz
*.rar
*.7z

# Documentation working files
~$*.docx
~$*.xlsx
~$*.pptx
